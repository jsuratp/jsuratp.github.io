---
interface Props {
  trend: {
    title: string;
    url: string;
    description: string;
    source: string;
    category: string;
    publishedAt: string;
    thumbnail?: string;
  };
}

const { trend } = Astro.props;

// Create a safe slug for the URL
const slug = trend.title
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, '-')
  .replace(/(^-|-$)/g, '');

const dateFormatted = new Date(trend.publishedAt).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
});
---

<article class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden hover:shadow-md transition-shadow duration-300">
  {trend.thumbnail && (
    <div class="aspect-video w-full overflow-hidden">
      <img 
        src={trend.thumbnail} 
        alt={trend.title} 
        class="w-full h-full object-cover hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    </div>
  )}
  <div class="p-6">
    <div class="flex items-center space-x-2 mb-3">
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800 uppercase tracking-wider">
        {trend.category}
      </span>
      <span class="text-xs text-gray-500">{dateFormatted}</span>
    </div>
    <h2 class="text-xl font-bold text-gray-900 mb-3 leading-tight group-hover:text-blue-600 transition">
      <a href={`/trend/${slug}`} class="hover:text-blue-600">
        {trend.title}
      </a>
    </h2>
    <p class="text-gray-600 text-sm line-clamp-3 mb-4 leading-relaxed">
      {trend.description}
    </p>
    <div class="flex items-center justify-between pt-4 border-t border-gray-50">
      <span class="text-xs font-medium text-gray-400">Source: {trend.source}</span>
      <a 
        href={`/trend/${slug}`} 
        class="text-blue-600 text-sm font-semibold hover:text-blue-700 flex items-center group"
      >
        Read More
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</article>
