---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found" description="The page you are looking for does not exist.">
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center">
    <h1 class="text-9xl font-extrabold text-blue-600 mb-4">404</h1>
    <h2 class="text-3xl font-bold text-gray-900 mb-8">Oops! Page not found</h2>
    <p class="text-xl text-gray-600 mb-12 max-w-md">
      The trending topic you're looking for might have moved or is no longer active.
    </p>
    <a href="/" class="bg-blue-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-blue-700 transition shadow-lg">
      Back to Home
    </a>
  </div>
</BaseLayout>
