---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrendCard from '../components/TrendCard.astro';
import trends from '../data/trends.json';

const title = "Today's Top Trending Topics";
const description = "Discover the latest trending topics in technology, finance, entertainment, and more. Stay updated with fresh content updated hourly.";

// Sort trends by date (newest first)
const sortedTrends = trends.sort((a, b) => 
  new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime()
);

const featuredTrend = sortedTrends[0];
const remainingTrends = sortedTrends.slice(1, 13);

const proxyImage = (url) => {
  if (!url) return "";
  if (url.startsWith('/') || url.includes('unsplash.com')) return url;
  
  // Remove HTML escape sequences
  let cleanUrl = url
    .replace(/&amp;/g, '&')
    .replace(/&lt;/g, '<')
    .replace(/&gt;/g, '>')
    .replace(/&quot;/g, '"')
    .replace(/&#39;/g, "'");
    
  // Force HTTPS
  cleanUrl = cleanUrl.replace("http://", "https://");
  
  return `https://images.weserv.nl/?url=${encodeURIComponent(cleanUrl)}&w=1200&fit=cover&q=80`;
};
---

<BaseLayout title={title} description={description}>
  <section class="mb-16">
    <div class="flex flex-col md:flex-row items-center justify-between mb-8 gap-6">
      <div class="max-w-2xl">
        <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 leading-tight tracking-tight mb-4">
          Stay Ahead with <span class="text-blue-600">TrendPulse</span>: Your Daily Guide to <span class="text-blue-600">Trending Topics</span>
        </h1>
        <p class="text-xl text-gray-600 leading-relaxed max-w-lg">
          We monitor thousands of signals across the web to bring you the most relevant <span class="font-semibold text-gray-900">trending news</span> in <span class="font-semibold text-gray-900">technology, finance, health, and entertainment</span> in real-time.
        </p>
      </div>
      <div class="w-full md:w-auto flex flex-col sm:flex-row gap-4">
        <div class="bg-blue-50 border border-blue-100 p-4 rounded-xl flex items-center space-x-4">
          <div class="h-10 w-10 bg-blue-100 rounded-lg flex items-center justify-center text-blue-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
          <div>
            <div class="text-sm font-bold text-blue-900">{trends.length}</div>
            <div class="text-xs text-blue-700">Active Trends</div>
          </div>
        </div>
        <div class="bg-green-50 border border-green-100 p-4 rounded-xl flex items-center space-x-4">
          <div class="h-10 w-10 bg-green-100 rounded-lg flex items-center justify-center text-green-600">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <div>
            <div class="text-sm font-bold text-green-900">Hourly</div>
            <div class="text-xs text-green-700">Updates</div>
          </div>
        </div>
      </div>
    </div>

    {featuredTrend && (
      <div class="relative group cursor-pointer overflow-hidden rounded-3xl shadow-2xl mb-12 bg-gray-900">
        <div class="aspect-video md:aspect-[21/9] w-full relative">
          {featuredTrend.thumbnail ? (
            <img 
              src={proxyImage(featuredTrend.thumbnail)} 
              alt={`Featured trend: ${featuredTrend.title}`}
              class="w-full h-full object-cover opacity-60 group-hover:scale-105 transition-transform duration-700"
              loading="lazy"
              referrerpolicy="no-referrer"
              onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
            />
          ) : null}
          <div class={`absolute inset-0 items-center justify-center bg-gradient-to-br from-blue-600 to-indigo-800 opacity-40 ${featuredTrend.thumbnail ? 'hidden' : 'flex'}`}>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-24 w-24 text-white opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
            </svg>
          </div>
        </div>
        <div class="absolute inset-0 flex flex-col justify-end p-8 md:p-12">
          <div class="max-w-3xl">
            <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-blue-600 text-white uppercase tracking-widest mb-6">
              Featured Trend
            </span>
            <h2 class="text-3xl md:text-5xl font-bold text-white mb-6 leading-tight drop-shadow-lg">
              <a href={`/trend/${featuredTrend.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`} class="hover:underline">
                {featuredTrend.title}
              </a>
            </h2>
            <p class="text-gray-200 text-lg md:text-xl line-clamp-2 mb-8 max-w-2xl drop-shadow-md">
              {featuredTrend.description}
            </p>
            <div class="flex items-center space-x-6">
               <a 
                href={`/trend/${featuredTrend.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`}
                class="bg-white text-blue-600 px-8 py-3 rounded-xl font-bold hover:bg-gray-100 transition shadow-lg inline-flex items-center"
              >
                Read Full Story
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7-7 7" />
                </svg>
              </a>
              <span class="text-gray-300 font-medium hidden sm:inline-block">Source: {featuredTrend.source}</span>
            </div>
          </div>
        </div>
      </div>
    )}

    <div class="flex items-center justify-between mb-8">
      <h3 class="text-2xl font-bold text-gray-900">Latest Trends</h3>
      <div class="flex space-x-2">
        {['Technology', 'Finance', 'Entertainment', 'Health', 'Gaming'].map(cat => (
          <a 
            href={`/category/${cat.toLowerCase()}`}
            class="hidden sm:inline-block px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-white hover:text-blue-600 hover:shadow-sm border border-transparent hover:border-gray-100 transition"
          >
            {cat}
          </a>
        ))}
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {remainingTrends.map(trend => (
        <TrendCard trend={trend} />
      ))}
    </div>

    <div class="mt-16 text-center">
      <a href="/archive" class="inline-flex items-center justify-center px-8 py-4 border border-gray-200 rounded-xl font-bold text-gray-600 hover:bg-white hover:shadow-md transition">
        View Historical Trends
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
