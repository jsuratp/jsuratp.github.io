---
import BaseLayout from '../../layouts/BaseLayout.astro';
import trends from '../../data/trends.json';

export function getStaticPaths() {
  return trends.map(trend => {
    const slug = trend.title
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/(^-|-$)/g, '');
    
    return {
      params: { slug },
      props: { trend }
    };
  });
}

const { trend } = Astro.props;
const { slug } = Astro.params;

const title = `${trend.title} - Trending News & Analysis`;
const description = `${trend.description.slice(0, 160)}... Learn more about the latest trending topic: ${trend.title}.`;
const categoryImages = {
  technology: 'https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1200&q=80',
  finance: 'https://images.unsplash.com/photo-1611974714024-462cd297bcff?auto=format&fit=crop&w=1200&q=80',
  entertainment: 'https://images.unsplash.com/photo-1603190287605-e6ade32fa852?auto=format&fit=crop&w=1200&q=80',
  health: 'https://images.unsplash.com/photo-1505751172876-fa1923c5c528?auto=format&fit=crop&w=1200&q=80',
  gaming: 'https://images.unsplash.com/photo-1542751371-adc38448a05e?auto=format&fit=crop&w=1200&q=80',
  general: 'https://images.unsplash.com/photo-1495020689067-958852a7765e?auto=format&fit=crop&w=1200&q=80'
};

const fallbackImage = categoryImages[trend.category.toLowerCase()] || categoryImages.general;
---

<BaseLayout 
  title={title} 
  description={description} 
  image={trend.thumbnail || fallbackImage}
  type="article"
  articleData={trend}
>
  <article class="max-w-4xl mx-auto py-12">
    <div class="flex items-center space-x-2 text-sm text-gray-500 mb-8">
      <a href="/" class="hover:text-blue-600">Home</a>
      <span>/</span>
      <a href={`/category/${trend.category.toLowerCase()}`} class="hover:text-blue-600">{trend.category}</a>
      <span>/</span>
      <span class="text-blue-600 font-medium line-clamp-1">{trend.title}</span>
    </div>

    <header class="mb-12">
      <div class="flex items-center space-x-3 mb-6">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-bold bg-blue-100 text-blue-800 uppercase tracking-widest">
          {trend.category}
        </span>
        <span class="text-gray-400 font-medium">•</span>
        <span class="text-gray-500 font-medium">{new Date(trend.publishedAt).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
      </div>
      <h1 class="text-4xl md:text-6xl font-extrabold text-gray-900 leading-tight mb-8">
        {trend.title}
      </h1>
      <div class="flex items-center justify-between py-6 border-y border-gray-100">
        <div class="flex items-center space-x-4">
          <div class="h-12 w-12 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-xl shadow-lg">
            {trend.source.charAt(0)}
          </div>
          <div>
            <div class="text-sm font-bold text-gray-900">Source: {trend.source}</div>
            <div class="text-xs text-gray-500">Curated via TrendPulse Engine</div>
          </div>
        </div>
        <div class="flex items-center space-x-3">
          <a 
            href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(trend.title)}&url=${encodeURIComponent(Astro.url.href)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2.5 rounded-full bg-gray-50 text-gray-600 hover:bg-blue-50 hover:text-blue-400 transition shadow-sm border border-gray-100"
            title="Share on Twitter"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z"/>
            </svg>
          </a>
          <a 
            href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.url.href)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="p-2.5 rounded-full bg-gray-50 text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition shadow-sm border border-gray-100"
            title="Share on Facebook"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/>
            </svg>
          </a>
          <button 
            onclick="navigator.clipboard.writeText(window.location.href); alert('Link copied!')"
            class="p-2.5 rounded-full bg-gray-50 text-gray-600 hover:bg-blue-50 hover:text-blue-600 transition shadow-sm border border-gray-100"
            title="Copy Link"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z" />
            </svg>
          </button>
        </div>
      </div>
    </header>

    <div class="aspect-video w-full mb-12 rounded-3xl overflow-hidden shadow-2xl bg-gray-100 relative">
      <img 
        src={trend.thumbnail || fallbackImage} 
        alt={`Main image for ${trend.title}`} 
        class="w-full h-full object-cover"
        onerror={`this.onerror=null; this.src='${fallbackImage}';`}
      />
    </div>

    <div class="prose prose-xl prose-blue max-w-none mb-16">
      <p class="text-2xl font-medium text-gray-700 leading-relaxed mb-8">
        {trend.description}
      </p>
      <div class="bg-gray-50 border-l-4 border-blue-600 p-8 rounded-r-2xl mb-12 shadow-sm">
        <h3 class="text-xl font-bold text-gray-900 mb-4">Latest Insights</h3>
        <p class="text-gray-700 leading-relaxed">
          The conversation around <strong>{trend.title}</strong> is evolving rapidly across social media and major news outlets. 
          Current sentiment suggests a high level of interest from {trend.category} enthusiasts and industry professionals alike.
        </p>
      </div>
      <p class="text-gray-700 leading-relaxed mb-8">
        Stay tuned as we continue to monitor this development. Our automated discovery engine scans thousands of sources every hour to provide the most up-to-date context on trending topics like this one.
      </p>
    </div>

    <div class="mt-16 pt-12 border-t border-gray-100">
      <h3 class="text-2xl font-bold text-gray-900 mb-8">Continue Reading</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        {trends.filter(t => t.title !== trend.title).slice(0, 2).map(t => (
          <div class="group cursor-pointer">
            <div class="aspect-video w-full bg-gray-100 rounded-2xl overflow-hidden mb-4 shadow-sm group-hover:shadow-md transition relative">
              {t.thumbnail ? (
                <img 
                  src={t.thumbnail} 
                  alt={`Related trend: ${t.title}`} 
                  class="w-full h-full object-cover group-hover:scale-105 transition duration-500"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
              ) : null}
              <div class={`absolute inset-0 flex items-center justify-center text-blue-200 ${t.thumbnail ? 'hidden' : 'flex'}`}>
                <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
            </div>
            <h4 class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition line-clamp-2">
              <a href={`/trend/${t.title.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '')}`}>
                {t.title}
              </a>
            </h4>
          </div>
        ))}
      </div>
    </div>
  </article>
</BaseLayout>
